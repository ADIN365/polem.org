# ─── PostgreSQL (Neon 권장) ─────────────────────────────────
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"
# Prisma migrate 시 connection pooling 우회용 (Neon: pooler 우회 URL)
# DIRECT_URL="postgresql://user:password@host-direct/db?sslmode=require"

# ─── NextAuth ───────────────────────────────────────────────
# 32바이트 random — `openssl rand -base64 32` 로 생성
NEXTAUTH_SECRET=""
# 로컬: http://localhost:3000 / 프로덕션: https://polem.org
NEXTAUTH_URL="http://localhost:3000"

# ─── 카카오 OAuth (kakao developers 등록) ───────────────────
# REST API 키 (Client ID), Client Secret (필수 활성화)
KAKAO_CLIENT_ID=""
KAKAO_CLIENT_SECRET=""

# ─── AI (Sprint 2 부터 사용. Sprint 1 엔 미사용) ────────────
# 초기: Max 요금제 안 claude -p 헤드리스 (별도 API 키 불필요)
# 나중: 아래 3개 fallback router
# ANTHROPIC_API_KEY=""
# OPENAI_API_KEY=""
# GOOGLE_GEMINI_API_KEY=""
