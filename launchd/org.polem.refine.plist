<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>org.polem.refine</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/sh</string>
    <string>-lc</string>
    <string>cd /Users/ddgeet/polem &amp;&amp; /opt/homebrew/bin/npx tsx scripts/refine-proposals.ts</string>
  </array>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
  </dict>

  <!-- 5분 주기 -->
  <key>StartInterval</key>
  <integer>300</integer>

  <key>RunAtLoad</key>
  <true/>

  <key>StandardOutPath</key>
  <string>/Users/ddgeet/polem/refine.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/ddgeet/polem/refine.log</string>

  <key>WorkingDirectory</key>
  <string>/Users/ddgeet/polem</string>
</dict>
</plist>
